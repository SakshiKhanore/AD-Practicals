package com.example.myexp;

import android.view.*;
import android.widget.TextView;
import android.widget.Toast;
import androidx.annotation.NonNull;
import androidx.recyclerview.widget.RecyclerView;
import java.util.List;

public class MovieAdapter extends RecyclerView.Adapter<MovieAdapter.ViewHolder> {

    List<Movie> movieList;

    public MovieAdapter(List<Movie> list) { this.movieList = list; }

    public static class ViewHolder extends RecyclerView.ViewHolder {
        TextView tvTitle, tvGenre;
        public ViewHolder(View v) {
            super(v);
            tvTitle = v.findViewById(R.id.tvTitle);
            tvGenre = v.findViewById(R.id.tvGenre);
        }
    }

    @NonNull
    @Override
    public ViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
        View v = LayoutInflater.from(parent.getContext())
                .inflate(R.layout.item_movie, parent, false);
        return new ViewHolder(v);
    }

    @Override
    public void onBindViewHolder(@NonNull ViewHolder holder, int position) {
        Movie m = movieList.get(position);
        holder.tvTitle.setText(m.title);
        holder.tvGenre.setText(m.genre);
        holder.itemView.setOnClickListener(v ->
            Toast.makeText(v.getContext(),
                "Selected: " + m.title, Toast.LENGTH_SHORT).show());
    }

    @Override
    public int getItemCount() { return movieList.size(); }
}

