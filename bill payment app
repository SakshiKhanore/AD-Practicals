package com.example.myexp;

import android.os.Bundle;
import android.widget.Button;
import androidx.appcompat.app.AppCompatActivity;
import androidx.fragment.app.FragmentTransaction;

public class MainActivity extends AppCompatActivity {
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        Button btnBill = findViewById(R.id.btnDest);
        Button btnPay  = findViewById(R.id.btnBook);

        loadFragment(new BillDetailsFragment());

        btnBill.setOnClickListener(v -> loadFragment(new BillDetailsFragment()));
        btnPay.setOnClickListener(v  -> loadFragment(new PaymentFragment()));
    }

    void loadFragment(androidx.fragment.app.Fragment f) {
        FragmentTransaction ft = getSupportFragmentManager().beginTransaction();
        ft.replace(R.id.fragmentContainer, f);
        ft.commit();
    }
}

