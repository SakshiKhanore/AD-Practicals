package com.example.myexp;

import android.content.Intent;
import android.os.Bundle;
import android.view.*;
import android.widget.*;
import androidx.fragment.app.Fragment;

public class MovieListFragment extends Fragment {
    @Override
    public View onCreateView(LayoutInflater inflater, ViewGroup container,
                             Bundle savedInstanceState) {
        View view = inflater.inflate(R.layout.fragment_movie_list, container, false);

        Spinner spinner   = view.findViewById(R.id.spinnerMovie);
        Button btnProceed = view.findViewById(R.id.btnProceed);

        String[] movies = {"Avengers", "RRR", "KGF", "Pathaan", "Jawan"};
        spinner.setAdapter(new ArrayAdapter<>(getContext(),
                android.R.layout.simple_spinner_dropdown_item, movies));

        btnProceed.setOnClickListener(v -> {
            String selected = spinner.getSelectedItem().toString();
            Intent intent = new Intent(getActivity(), BookingActivity.class);
            intent.putExtra("MOVIE", selected);
            startActivity(intent);
        });
        return view;
    }
}

