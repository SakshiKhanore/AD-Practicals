package com.example.myexp;

import android.os.Bundle;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;

public class ResultActivity extends AppCompatActivity {
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        TextView tv = new TextView(this);
        tv.setTextSize(18);
        tv.setPadding(40, 40, 40, 40);
        tv.setText("Registration Details\n\n" +
            "Name: "          + getIntent().getStringExtra("NAME")          + "\n" +
            "Subject: "       + getIntent().getStringExtra("SUBJECT")       + "\n" +
            "Gender: "        + getIntent().getStringExtra("GENDER")        + "\n" +
            "Qualification: " + getIntent().getStringExtra("QUALIFICATION"));
        setContentView(tv);
    }
}
